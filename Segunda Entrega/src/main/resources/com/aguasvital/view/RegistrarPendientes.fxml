<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aguasvital.controller.RegistrarPendientesController"
            prefWidth="950" prefHeight="680">
    <top><HBox style="-fx-padding: 16; -fx-background-color: #eaf3f8;"><children><Label fx:id="lblTitulo" text="Registrar Pendientes" style="-fx-font-size: 20px; -fx-font-weight: bold;" /></children></HBox></top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <children>
                <TableView fx:id="tblPendientes" prefHeight="430">
                    <columns>
                        <TableColumn fx:id="colNumero" text="Numero" prefWidth="90" /><TableColumn fx:id="colFecha" text="Fecha" prefWidth="110" />
                        <TableColumn fx:id="colCliente" text="Cliente" prefWidth="160" /><TableColumn fx:id="colDireccion" text="Direccion" prefWidth="180" />
                        <TableColumn fx:id="colBarrio" text="Barrio" prefWidth="120" /><TableColumn fx:id="colZona" text="Zona" prefWidth="120" />
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="110" /><TableColumn fx:id="colDistribuidor" text="Distribuidor asignado" prefWidth="170" />
                    </columns>
                </TableView>
                <HBox spacing="10"><children><ComboBox fx:id="cmbDistribuidor" promptText="Seleccionar distribuidor" prefWidth="260" /><Button text="Reasignar pedido" onAction="#reasignar" /><Button text="Actualizar" onAction="#actualizar" /></children></HBox>
            </children>
        </VBox>
    </center>
    <bottom><HBox alignment="CENTER_RIGHT" style="-fx-padding: 16;"><children><Button text="Volver" onAction="#volverMenu" /></children></HBox></bottom>
</BorderPane>
