<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aguasvital.controller.LoginController"
      alignment="CENTER" spacing="14" prefWidth="420" prefHeight="370" style="-fx-padding: 36;">
    <children>
        <Label text="AGUAS VITAL" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label text="Sistema de gestion de pedidos" />
        <TextField fx:id="txtUsuario" promptText="Usuario" prefWidth="280" />
        <PasswordField fx:id="txtPassword" promptText="Contrasena" prefWidth="280" />
        <Button text="Iniciar sesion" onAction="#iniciarSesion" prefWidth="280" />
        <Label fx:id="lblError" textFill="#b00020" />
    </children>
</VBox>
