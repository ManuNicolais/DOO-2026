<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aguasvital.controller.GestionarPreciosController"
            prefWidth="950" prefHeight="680">
    <top><HBox style="-fx-padding: 16; -fx-background-color: #eaf3f8;"><children><Label fx:id="lblTitulo" text="Gestionar / Consultar Precios" style="-fx-font-size: 20px; -fx-font-weight: bold;" /></children></HBox></top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <children>
                <TableView fx:id="tblPrecios" prefHeight="430">
                    <columns>
                        <TableColumn fx:id="colCodigo" text="Codigo" prefWidth="100" /><TableColumn fx:id="colProducto" text="Producto" prefWidth="220" />
                        <TableColumn fx:id="colEnvase" text="Envase" prefWidth="130" /><TableColumn fx:id="colCapacidad" text="Capacidad" prefWidth="120" />
                        <TableColumn fx:id="colPrecioActual" text="Precio actual" prefWidth="150" /><TableColumn fx:id="colFechaDesde" text="Fecha desde" prefWidth="140" />
                    </columns>
                </TableView>
                <HBox spacing="10"><children><TextField fx:id="txtNuevoPrecio" promptText="Nuevo precio" /><DatePicker fx:id="dpNuevaFechaDesde" promptText="Nueva fecha desde" /><Button fx:id="btnModificarPrecio" text="Modificar precio" onAction="#modificarPrecio" /><Button text="Limpiar" onAction="#limpiar" /></children></HBox>
            </children>
        </VBox>
    </center>
    <bottom><HBox alignment="CENTER_RIGHT" style="-fx-padding: 16;"><children><Button text="Volver" onAction="#volverMenu" /></children></HBox></bottom>
</BorderPane>
