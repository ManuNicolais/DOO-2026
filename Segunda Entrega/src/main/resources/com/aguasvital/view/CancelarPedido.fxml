<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aguasvital.controller.CancelarPedidoController"
            prefWidth="950" prefHeight="680">
    <top><HBox style="-fx-padding: 16; -fx-background-color: #eaf3f8;"><children><Label fx:id="lblTitulo" text="Cancelar Pedido" style="-fx-font-size: 20px; -fx-font-weight: bold;" /></children></HBox></top>
    <center>
        <VBox spacing="14" style="-fx-padding: 24;">
            <children>
                <HBox spacing="10"><children><TextField fx:id="txtNumeroPedido" promptText="Numero de pedido" /><Button fx:id="btnBuscar" text="Buscar" onAction="#buscar" /></children></HBox>
                <GridPane hgap="12" vgap="10">
                    <children>
                        <Label text="Cliente" GridPane.rowIndex="0" GridPane.columnIndex="0" /><TextField fx:id="txtCliente" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label text="Fecha" GridPane.rowIndex="0" GridPane.columnIndex="2" /><TextField fx:id="txtFecha" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3" />
                        <Label text="Estado" GridPane.rowIndex="1" GridPane.columnIndex="0" /><TextField fx:id="txtEstado" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label text="Total" GridPane.rowIndex="1" GridPane.columnIndex="2" /><TextField fx:id="txtTotal" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                    </children>
                </GridPane>
                <TextArea fx:id="txtMotivo" promptText="Motivo de cancelacion" prefRowCount="5" />
            </children>
        </VBox>
    </center>
    <bottom><HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 16;"><children><Button fx:id="btnConfirmar" text="Confirmar cancelacion" onAction="#confirmar" /><Button fx:id="btnLimpiar" text="Limpiar" onAction="#limpiar" /><Button fx:id="btnVolver" text="Volver" onAction="#volverMenu" /></children></HBox></bottom>
</BorderPane>
