<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aguasvital.controller.RegistrarClienteController"
            prefWidth="950" prefHeight="680">
    <top><HBox style="-fx-padding: 16; -fx-background-color: #eaf3f8;"><children><Label fx:id="lblTitulo" text="Registrar Cliente" style="-fx-font-size: 20px; -fx-font-weight: bold;" /></children></HBox></top>
    <center>
        <GridPane hgap="14" vgap="12" style="-fx-padding: 24;">
            <children>
                <Label text="Tipo documento" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <ComboBox fx:id="cboTipoDocumento" promptText="DNI / CUIT" prefWidth="240" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Label text="Numero documento" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                <TextField fx:id="txtNroDoc" promptText="Numero" GridPane.rowIndex="0" GridPane.columnIndex="3" />
                <Label text="Nombre" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="txtNombre" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label text="Apellido" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                <TextField fx:id="txtApellido" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                <Label text="Razon social" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="txtRazonSocial" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Telefono" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                <TextField fx:id="txtTelefono" GridPane.rowIndex="2" GridPane.columnIndex="3" />
                <Label text="Direccion" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="txtDireccion" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                <Label text="Zona" GridPane.rowIndex="3" GridPane.columnIndex="2" />
                <ComboBox fx:id="cboZona" promptText="Seleccione zona" GridPane.rowIndex="3" GridPane.columnIndex="3" />
                <Label text="Barrio" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <ComboBox fx:id="cboBarrio" promptText="Seleccione barrio" GridPane.rowIndex="4" GridPane.columnIndex="1" />
            </children>
        </GridPane>
    </center>
    <bottom><HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 16;"><children><Button fx:id="btnGuardar" text="Guardar" onAction="#guardar" /><Button fx:id="btnLimpiar" text="Limpiar" onAction="#limpiar" /><Button fx:id="btnVolver" text="Volver" onAction="#volverMenu" /></children></HBox></bottom>
</BorderPane>
