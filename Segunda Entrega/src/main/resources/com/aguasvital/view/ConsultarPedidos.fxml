<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aguasvital.controller.ConsultarPedidosController"
            prefWidth="950" prefHeight="680">
    <top><HBox style="-fx-padding: 16; -fx-background-color: #eaf3f8;"><children><Label fx:id="lblTitulo" text="Consultar Pedidos" style="-fx-font-size: 20px; -fx-font-weight: bold;" /></children></HBox></top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <children>
                <HBox spacing="10"><children><TextField fx:id="txtNumeroPedido" promptText="Numero de pedido" /><TextField fx:id="txtCliente" promptText="Cliente" /><DatePicker fx:id="dpFecha" promptText="Fecha" /><ComboBox fx:id="cmbEstado" promptText="Estado" /><Button text="Buscar" onAction="#buscar" /><Button text="Limpiar" onAction="#limpiar" /></children></HBox>
                <TableView fx:id="tblPedidos" prefHeight="420">
                    <columns>
                        <TableColumn fx:id="colNumero" text="Numero" prefWidth="100" /><TableColumn fx:id="colCliente" text="Cliente" prefWidth="190" />
                        <TableColumn fx:id="colFechaEmision" text="Fecha emision" prefWidth="140" /><TableColumn fx:id="colFechaEntrega" text="Fecha entrega" prefWidth="140" />
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="130" /><TableColumn fx:id="colTotal" text="Total" prefWidth="120" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    <bottom><HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 16;"><children><Button text="Ver detalle" onAction="#verDetalle" /><Button text="Volver" onAction="#volverMenu" /></children></HBox></bottom>
</BorderPane>
