<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aguasvital.controller.GenerarRendicionController"
            prefWidth="950" prefHeight="680">
    <top>
        <HBox spacing="12" style="-fx-padding: 16; -fx-background-color: #eaf3f8;">
            <children>
                <Label text="Generar Rendicion Diaria" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 18;">
            <children>
                <HBox spacing="10">
                    <children>
                        <DatePicker fx:id="dpFecha" />
                        <Button text="Generar" onAction="#generarRendicion" />
                    </children>
                </HBox>
                <TableView fx:id="tblPedidos" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="colNroPedido" text="Nro" prefWidth="80" />
                        <TableColumn fx:id="colCliente" text="Cliente" prefWidth="170" />
                        <TableColumn fx:id="colBarrio" text="Barrio" prefWidth="120" />
                        <TableColumn fx:id="colZona" text="Zona" prefWidth="120" />
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="120" />
                        <TableColumn fx:id="colMetodoPago" text="Metodo pago" prefWidth="180" />
                        <TableColumn fx:id="colTotal" text="Total" prefWidth="100" />
                    </columns>
                </TableView>
                <GridPane hgap="12" vgap="10">
                    <children>
                        <Label text="Entregados" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <Label fx:id="lblEntregados" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label text="No entregados" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                        <Label fx:id="lblNoEntregados" GridPane.rowIndex="0" GridPane.columnIndex="3" />
                        <Label text="Pendientes" GridPane.rowIndex="0" GridPane.columnIndex="4" />
                        <Label fx:id="lblPendientes" GridPane.rowIndex="0" GridPane.columnIndex="5" />
                        <Label text="Total ingresos" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <Label fx:id="lblTotalGeneral" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label text="Total contado" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                        <Label fx:id="lblTotalContado" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                        <Label text="Total electronico" GridPane.rowIndex="1" GridPane.columnIndex="4" />
                        <Label fx:id="lblTotalElectronico" GridPane.rowIndex="1" GridPane.columnIndex="5" />
                    </children>
                </GridPane>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 16;">
            <children>
                <Button text="Volver al menu" onAction="#volverMenu" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
